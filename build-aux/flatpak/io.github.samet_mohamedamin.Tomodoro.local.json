{
  "app-id": "io.github.samet_mohamedamin.Tomodoro",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "tomodoro",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=org.gnome.evolution.dataserver.Sources5",
    "--talk-name=org.gnome.evolution.dataserver.Calendar8",
    "--filesystem=~/contexts:create"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/vala"
  ],
  "modules": [
    {
      "name": "libical",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_INSTALL_LIBDIR=lib",
        "-DSHARED_ONLY=true",
        "-DWITH_CXX_BINDINGS=false",
        "-DICAL_BUILD_DOCS=false",
        "-DICAL_GLIB=true",
        "-DGOBJECT_INTROSPECTION=true",
        "-DICAL_GLIB_VAPI=true",
        "-DLIBICAL_BUILD_TESTING=false",
        "-DLIBICAL_BUILD_EXAMPLES=false",
        "-DENABLE_GTK_DOC=false"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/libical/libical/releases/download/v3.0.20/libical-3.0.20.tar.gz",
          "sha256": "e73de92f5a6ce84c1b00306446b290a2b08cdf0a80988eca0a2c9d5c3510b4c2"
        }
      ]
    },
    {
      "name": "evolution-data-server",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_INSTALL_LIBDIR=lib",
        "-DENABLE_BACKEND_PER_PROCESS=OFF",
        "-DENABLE_GOA=OFF",
        "-DENABLE_GTK=OFF",
        "-DENABLE_GTK4=OFF",
        "-DENABLE_OAUTH2_WEBKITGTK=OFF",
        "-DENABLE_OAUTH2_WEBKITGTK4=OFF",
        "-DENABLE_EXAMPLES=OFF",
        "-DENABLE_TESTS=OFF",
        "-DENABLE_INSTALLED_TESTS=OFF",
        "-DENABLE_GTK_DOC=OFF",
        "-DENABLE_GI_DOCGEN=OFF",
        "-DENABLE_VALA_BINDINGS=ON",
        "-DENABLE_INTROSPECTION=ON",
        "-DENABLE_WEATHER=OFF",
        "-DENABLE_CANBERRA=OFF",
        "-DENABLE_SMIME=ON",
        "-DWITH_PRIVATE_DOCS=OFF",
        "-DWITH_LIBDB=OFF",
        "-DWITH_KRB5=OFF",
        "-DWITH_OPENLDAP=OFF",
        "-DWITH_PHONENUMBER=OFF",
        "-DWITH_SYSTEMDUSERUNITDIR=no"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/evolution-data-server/3.60/evolution-data-server-3.60.2.tar.xz",
          "sha256": "2084dbdac396371b365d504c1ff45866ba8dca2f1252e5da1d3d9c33abdc1286"
        }
      ]
    },
    {
      "name": "tomodoro",
      "buildsystem": "meson",
      "builddir": true,
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
