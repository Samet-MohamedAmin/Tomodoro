<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APPLICATION_ID@</id>
  <name>@APPLICATION_NAME@</name>
  <summary>Plan todo.txt tasks and work through them with Pomodoro sessions</summary>
  <developer id="io.github.samet_mohamedamin">
    <name>Mohamed Amin</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>
      Todo + Pomodoro = Tomodoro. Tomodoro combines a todo.txt task list
      with a Pomodoro timer, so you can plan work and track how much focused
      effort is still left.
    </p>
    <p>
      Tasks can have contexts, projects, priorities, due dates, dependencies,
      recurring schedules, and remaining pomodoros. The timer works against
      the selected task, helping you move from a list of things to do into a
      focused work session.
    </p>
    <p>
      Tomodoro stores tasks as plain text files and includes GNOME integration
      such as desktop notifications, an app indicator, and optional calendar
      events.
    </p>
  </description>
  <launchable type="desktop-id">@APPLICATION_ID@.desktop</launchable>
  <categories>
    <category>Office</category>
    <category>ProjectManagement</category>
    <category>Utility</category>
  </categories>
  <url type="homepage">https://github.com/Samet-MohamedAmin/Tomodoro</url>
  <url type="bugtracker">https://github.com/Samet-MohamedAmin/Tomodoro/issues</url>
  <url type="vcs-browser">https://github.com/Samet-MohamedAmin/Tomodoro</url>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Samet-MohamedAmin/Tomodoro/main/images/screenshot-list.png</image>
      <caption>Plan tasks with priorities, due dates, projects, and remaining pomodoros</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Samet-MohamedAmin/Tomodoro/main/images/screenshot-timer.png</image>
      <caption>Run a Pomodoro session for the selected todo</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Samet-MohamedAmin/Tomodoro/main/images/screenshot-editor.png</image>
      <caption>Create todos with priority, due date, and pomodoro estimates</caption>
    </screenshot>
  </screenshots>
  <content_rating type="oars-1.1" />
