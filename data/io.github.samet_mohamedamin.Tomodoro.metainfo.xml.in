    </release>
    <release version="0.1.23" date="2026-06-23">
      <description>
        <ul>
          <li>Add a Recurring order view for recurring todo templates and put Due first in the order menu.</li>
          <li>Remember folded list sections across normal refreshes and reset them on context, project, or order changes.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.22" date="2026-06-23">
      <description>
        <ul>
          <li>Block New/Edit Todo due dates before today and show near dates as Today/Tomorrow labels after calendar selection.</li>
          <li>Render dependency graphs in every list grouping mode, with All Projects grouped by main project priority.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.21" date="2026-06-23">
      <description>
        <ul>
          <li>Add Daily, Weekly, and Monthly recurring todos with due-date validation.</li>
          <li>Roll completed recurring todos forward and project recurring calendar events for the next 40 days.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.20" date="2026-06-23">
      <description>
        <ul>
          <li>Filter child priority choices to the selected parent priority and lower priorities.</li>
          <li>Refresh available priorities immediately when the selected dependency changes.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.19" date="2026-06-23">
